{
	"name": "express-starter-template",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/server.ts",
		"format:all": "biome format --write .",
		"lint:all": "biome lint --fix .",
		"check:all": "biome check --fix .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/bun": "^1.3.14",
		"@types/express": "^5.0.6",
		"@types/http-errors": "^2.0.5",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.2.0",
		"drizzle-kit": "^1.0.0-rc.4",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsx": "^4.23.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"dependencies": {
		"@types/bcrypt": "^6.0.0",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^1.0.0-rc.4",
		"express": "^5.2.1",
		"express-validator": "^7.3.2",
		"http-errors": "^2.0.1",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.22.0",
		"supertest": "^7.2.2",
		"winston": "^3.19.0"
	}
}
